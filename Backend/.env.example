# ── Gemini API ──────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── Supabase / PostgreSQL ───────────────────────────────────────
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.ghxjypqokuqlhexqpjuf.supabase.co:5432/postgres

# ── Auth ────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-secret-key-here

# ── Batch Processing ────────────────────────────────────────────
BATCH_SIZE=10
BATCH_DELAY_SECONDS=65
MAX_RETRIES=3
RETRY_WAIT_SECONDS=90
CONFIDENCE_THRESHOLD=0.75

# ── File Handling ───────────────────────────────────────────────
UPLOAD_DIR=/tmp/billscan/uploads
OUTPUT_DIR=/tmp/billscan/outputs
MAX_FILE_SIZE_MB=10
AUTO_DELETE_HOURS=2
ALLOWED_EXTENSIONS=["jpg","jpeg","png","pdf","heic"]

# ── Server ──────────────────────────────────────────────────────
# Replace https://your-app.vercel.app with your actual Vercel frontend URL
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","https://your-app.vercel.app"]
